# Copy to terraform.tfvars and fill in
# Never commit terraform.tfvars

aws_region   = "us-east-1"
environment = "dev"
project      = "taskforge"

# Required — use strong password; consider Secrets Manager for production
db_password = "REPLACE_WITH_STRONG_PASSWORD"

# Optional
owner               = "platform-team"
cost_center         = "platform"
data_classification = "internal"

# Dev: smaller; prod: larger
# eks_node_instance_types = ["t3.medium"]
# rds_instance_class      = "db.t3.micro"

# Prod: restrict EKS API to VPC (kubectl from bastion/VPN)
# eks_endpoint_public_access = false

# Observability (default: true)
# enable_cloudtrail = true
